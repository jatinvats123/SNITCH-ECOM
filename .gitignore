# Dependencies
node_modules/

# Environment variables — never commit secrets.
# Ignore .env and every variant (.env.local, .env.production, ...),
# but always allow committed example templates (*.example).
.env
.env.*
!*.example

# Logs
*.log
npm-debug.log*

